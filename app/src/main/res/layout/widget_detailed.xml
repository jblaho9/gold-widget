<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GOLD · XAU/USD"
            android:textColor="#FFD700"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tv_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="@color/price_up"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main price -->
    <TextView
        android:id="@+id/tv_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$0,000.00"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginTop="1dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="per troy ounce"
        android:textColor="#50FFFFFF"
        android:textSize="9sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#25FFD700"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Stats row: High / Low / Open / Prev Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- High -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:textColor="#60FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/price_up"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Low -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW"
                android:textColor="#60FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/price_down"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Open -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPEN"
                android:textColor="#60FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_open"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Prev Close -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREV"
                android:textColor="#60FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_prev_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Updated time -->
    <TextView
        android:id="@+id/tv_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Updated --:-- --"
        android:textColor="#35FFFFFF"
        android:textSize="8sp"
        android:layout_marginTop="6dp" />

</LinearLayout>
