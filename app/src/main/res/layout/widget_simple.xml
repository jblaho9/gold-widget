<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="11dp">

    <!-- Header row: GOLD label left, change pill right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GOLD"
            android:textColor="#FFD700"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.22" />

        <ImageView
            android:id="@+id/iv_market_closed"
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:src="@drawable/ic_pause"
            android:visibility="gone"
            android:layout_marginEnd="5dp" />

        <TextView
            android:id="@+id/tv_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="@color/price_up"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/pill_up"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

    <!-- Price — tight below header -->
    <TextView
        android:id="@+id/tv_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$0,000"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:layout_marginTop="2dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Timestamp + refresh button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_updated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--:-- --"
            android:textColor="#33FFFFFF"
            android:textSize="7sp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_refresh"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="3dp" />
    </LinearLayout>

</LinearLayout>
